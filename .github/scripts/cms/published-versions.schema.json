{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["published"],
  "properties": {
    "published": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["project", "version"],
        "properties": {
          "project": { "type": "string" },
          "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+" },
          "locales": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional. When omitted, all locales for this version are treated as published."
          },
          "published_at": { "type": "string", "format": "date-time" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
