{
  "frontend_locales_path": "../ComfyUI_frontend/src/locales",
  "skip_paths": ["built-in-nodes"],
  "chunked_files": [
    {
      "path": "changelog/index.mdx",
      "strategy": "update_blocks"
    },
    {
      "path": "tutorials/partner-nodes/pricing.mdx",
      "strategy": "heading_sections"
    }
  ],
  "auto_chunk": {
    "min_body_chars": 3000,
    "min_sections": 2
  },
  "languages": [
    {
      "code": "ja",
      "name": "Japanese",
      "dir": "ja",
      "snippets_dir": "snippets/ja"
    },
    {
      "code": "zh",
      "name": "Simplified Chinese",
      "dir": "zh",
      "snippets_dir": "snippets/zh"
    },
    {
      "code": "ko",
      "name": "Korean",
      "dir": "ko",
      "snippets_dir": "snippets/ko"
    }
  ],
  "preserve_terms": [
    "ComfyUI", "Comfy Cloud", "LoRA", "VAE", "CLIP", "checkpoint", "ControlNet",
    "KSampler", "UNet", "API", "JSON", "MDX", "GitHub", "Hugging Face",
    "Civitai", "ComfyUI Manager", "safetensors", "GGUF", "SDXL", "SD1.5",
    "Stable Diffusion", "Black Forest Labs", "Stability AI", "RealESRGAN",
    "embedding", "scheduler", "sampler", "latent", "conditioning",
    "inpainting", "outpainting", "upscale", "diffusion", "tokenizer",
    "denoise", "T5", "T2I", "IPAdapter", "InstantID", "AnimateDiff",
    "Flux", "diffusers", "tensor", "pipeline", "node graph"
  ]
}
